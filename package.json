{
  "name": "n8n-nodes-pocketbase",
  "version": "2.0.0",
  "description": "Interact with your PocketBase instance",
  "keywords": [
    "n8n-community-node-package"
  ],
  "homepage": "https://github.com/TheFehr/n8n-nodes-pocketbase#readme",
  "license": "MIT",
  "author": {
    "name": "Philipp Fehr",
    "email": "philipp@thefehr.ch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheFehr/n8n-nodes-pocketbase.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:pipeline": "bash scripts/full-test.sh",
    "version:update": "tsx scripts/update-versions.ts",
    "version:check": "tsx scripts/update-versions.ts --check",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "dependencies": {
    "eventsource": "^4.1.0"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "release-it": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "n8n-workflow": "^2.16.1"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/PocketbaseHttpApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PocketbaseHttp/PocketbaseHttp.node.js",
      "dist/nodes/PocketbaseTrigger/PocketbaseTrigger.node.js"
    ]
  },
  "pocketbaseVersion": "0.36.9"
}
